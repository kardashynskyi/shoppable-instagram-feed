<div
  class="sig-feed"
  data-shop="{{ shop.permanent_domain }}"
  data-limit="{{ block.settings.limit }}"
>
  <div class="sig-feed__header">
    <p class="sig-feed__eyebrow">{{ block.settings.eyebrow }}</p>
    <h2 class="sig-feed__heading">{{ block.settings.heading }}</h2>
  </div>

  <div class="sig-feed__grid" id="sig-feed-{{ block.id }}">
    <p>Instagram feed will load here.</p>
  </div>
</div>

<style>
  .sig-feed {
    max-width: {{ block.settings.width }}px;
    margin: 0 auto;
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
  }

  .sig-feed__header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 28px;
  }

  .sig-feed__eyebrow {
    margin: 0 0 10px;
    font-size: 13px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.65;
  }

  .sig-feed__heading {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .sig-feed__grid {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns }}, 1fr);
    gap: {{ block.settings.gap }}px;
  }

  .sig-feed__item {
    position: relative;
    display: block;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #f4f4f4;
    border-radius: {{ block.settings.image_radius }}px;
  }

  .sig-feed__item img,
  .sig-feed__item video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media screen and (max-width: 768px) {
    .sig-feed {
      padding: {{ block.settings.padding_top_mobile }}px 0 {{ block.settings.padding_bottom_mobile }}px 16px;
    }

    .sig-feed__header {
      display: block;
      padding-right: 16px;
    }

    .sig-feed__grid {
      display: flex;
      overflow-x: auto;
      gap: {{ block.settings.gap_mobile }}px;
      padding-right: 16px;
      scroll-snap-type: x mandatory;
    }

    .sig-feed__item {
      flex: 0 0 72%;
      scroll-snap-align: start;
    }
  }
</style>

{% schema %}
{
  "name": "Shoppable Instagram Feed",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Follow us"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop our Instagram"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Number of posts",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Desktop columns",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 6
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Desktop gap",
      "min": 0,
      "max": 32,
      "step": 1,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Mobile gap",
      "min": 0,
      "max": 24,
      "step": 1,
      "default": 10,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 22,
      "max": 72,
      "step": 1,
      "default": 42,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "width",
      "label": "Section width",
      "min": 900,
      "max": 1800,
      "step": 20,
      "default": 1400,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top spacing desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom spacing desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top spacing mobile",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 44,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom spacing mobile",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 44,
      "unit": "px"
    }
  ]
}
{% endschema %}