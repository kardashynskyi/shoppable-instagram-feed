<div
  class="sig-feed"
  data-shop="{{ shop.permanent_domain }}"
  data-limit="{{ block.settings.limit }}"
  data-api-url="https://shoppable-instagram-feed.onrender.com/api/instagram-feed"
>
  <div class="sig-feed__header">
    <p class="sig-feed__eyebrow">{{ block.settings.eyebrow }}</p>
    <h2 class="sig-feed__heading">{{ block.settings.heading }}</h2>
  </div>

  <div class="sig-feed__grid" id="sig-feed-{{ block.id }}">
    <p>Loading Instagram feed...</p>
  </div>
</div>

<script>
  (() => {
    const section = document.currentScript.previousElementSibling;
    const grid = section.querySelector(".sig-feed__grid");
    const shop = section.dataset.shop;
    const limit = Number(section.dataset.limit || 6);
    const apiUrl = section.dataset.apiUrl;

    fetch(`${apiUrl}?shop=${encodeURIComponent(shop)}`)
      .then((response) => response.json())
      .then((data) => {
        const posts = (data.posts || []).slice(0, limit);

        if (!posts.length) {
          grid.innerHTML = "<p>No Instagram posts found.</p>";
          return;
        }

        grid.innerHTML = posts
          .map((post) => {
            const tag = post.tags && post.tags[0];
            const href = tag?.productHandle
              ? `/products/${tag.productHandle}`
              : tag?.collectionHandle
                ? `/collections/${tag.collectionHandle}`
                : post.permalink || "#";

            return `
              <a class="sig-feed__item" href="${href}">
                ${
                  post.mediaType === "VIDEO"
                    ? `<video src="${post.mediaUrl}" muted loop playsinline></video>`
                    : `<img src="${post.mediaUrl}" alt="${post.caption || "Instagram post"}" loading="lazy">`
                }

                ${
                  tag
                    ? `<span class="sig-feed__badge">Shop now</span>`
                    : ""
                }
              </a>
            `;
          })
          .join("");
      })
      .catch(() => {
        grid.innerHTML = "<p>Instagram feed could not be loaded.</p>";
      });
  })();
</script>