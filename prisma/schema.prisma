// This is your Prisma schema file.
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?

  @@index([shop])
}

model InstagramAccount {
  id   String @id @default(cuid())
  shop String @unique

  // Meta asset identifiers.
  pageId        String?
  instagramId   String?
  facebookUserId String?
  username      String?

  // Meta authorization.
  //
  // This value will be encrypted before it is written by the server code.
  // It must never be returned to the browser or storefront API.
  accessToken String?

  tokenType      String?
  tokenIssuedAt  DateTime?
  tokenExpiresAt DateTime?
  grantedScopes  String?

  // Connection lifecycle.
  connected          Boolean   @default(false)
  reconnectRequired  Boolean   @default(false)
  connectedAt        DateTime?
  disconnectedAt     DateTime?
  lastTokenCheckedAt DateTime?

  // Sync lifecycle.
  lastSyncedAt      DateTime?
  lastSyncError     String?
  lastSyncErrorCode String?

  // Used to prevent two sync operations from running simultaneously.
  syncInProgress Boolean   @default(false)
  syncStartedAt  DateTime?

  posts InstagramPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pageId])
  @@index([instagramId])
  @@index([connected])
  @@index([reconnectRequired])
}

model InstagramPost {
  id          String  @id @default(cuid())
  shop        String
  instagramId String? @unique
  accountId   String?

  mediaUrl     String
  permalink    String?
  caption      String?
  mediaType    String  @default("IMAGE")
  thumbnailUrl String?
  timestamp    DateTime?

  isPublished Boolean @default(true)

  account InstagramAccount? @relation(
    fields: [accountId],
    references: [id],
    onDelete: SetNull
  )

  tags InstagramPostTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
  @@index([accountId])
  @@index([shop, isPublished])
  @@index([shop, timestamp])
}

model InstagramPostTag {
  id     String @id @default(cuid())
  shop   String
  postId String

  productId     String?
  variantId     String?
  productHandle String?
  productTitle  String?

  collectionId     String?
  collectionHandle String?
  collectionTitle  String?

  xPosition Float?
  yPosition Float?

  post InstagramPost @relation(
    fields: [postId],
    references: [id],
    onDelete: Cascade
  )

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
  @@index([postId])
  @@index([productId])
  @@index([variantId])
  @@index([collectionId])
}