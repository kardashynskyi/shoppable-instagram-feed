// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}
model InstagramAccount {
  id          String  @id @default(cuid())

  // One connected Instagram account per Shopify store.
  shop        String  @unique

  // Meta identifiers.
  pageId      String?
  instagramId String?
  username    String?

  // Must only be read server-side.
  accessToken String?
  tokenExpiresAt DateTime?

  connected   Boolean @default(false)

  // Sync status.
  lastSyncedAt DateTime?
  lastSyncError String?

  posts InstagramPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InstagramPost {
  id             String   @id @default(cuid())
  shop           String
  instagramId    String?  @unique
  accountId      String?

  mediaUrl       String
  permalink      String?
  caption        String?
  mediaType      String   @default("IMAGE") // IMAGE, VIDEO, CAROUSEL_ALBUM, STORY
  thumbnailUrl   String?
  timestamp      DateTime?

  isPublished    Boolean  @default(true)

  account        InstagramAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  tags           InstagramPostTag[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([shop])
  @@index([accountId])
}

model InstagramPostTag {
  id              String   @id @default(cuid())
  shop            String
  postId          String

  productId       String?
  variantId       String?
  productHandle   String?
  productTitle    String?

  collectionId    String?
  collectionHandle String?
  collectionTitle  String?

  xPosition       Float?
  yPosition       Float?

  post            InstagramPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([shop])
  @@index([postId])
  @@index([productId])
  @@index([collectionId])
}